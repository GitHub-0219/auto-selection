# Auto选品项目 - 反扒机制环境配置示例
# 复制此文件为 .env 并修改相应值

# ============ 服务器配置 ============
PORT=3000
NODE_ENV=production

# ============ 反扒机制配置 ============

# IP限流
RATE_LIMIT_IP_WINDOW_MS=60000
RATE_LIMIT_IP_MAX=100

# 用户限流
RATE_LIMIT_USER_WINDOW_MS=60000
RATE_LIMIT_USER_MAX=50

# API限流
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_API_MAX=20

# ============ 加密配置 ============
# 生成强密钥: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SIGNATURE_SECRET=your-secure-signature-key-here
CAPTCHA_SECRET=your-captcha-secret-here
ENCRYPTION_KEY=your-encryption-key-here

# ============ Redis配置 ============
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============ 管理配置 ============
# 生成强密钥: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=your-admin-api-key-here

# ============ 日志配置 ============
LOG_LEVEL=info
LOG_FILE=./logs/anti-scraping.log

# ============ 前端配置 ============
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_CAPTCHA_ENABLED=true
