# ===========================================
# Auto选品 - 后端环境配置
# ===========================================

# 数据库
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_cross_border?schema=public"

# 应用配置
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# JWT认证
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# 登录安全
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=900

# ===========================================
# AI服务配置
# ===========================================

# AI提供商: siliconflow | mock
AI_PROVIDER="mock"

# 硅基流动API (https://account.siliconflow.cn)
SILICONFLOW_API_KEY="sk-your-api-key-here"
SILICONFLOW_MODEL="Qwen/Qwen2.5-7B-Instruct"

# OpenAI API (备选)
OPENAI_API_KEY="sk-your-openai-key"

# ===========================================
# 微信支付配置
# ===========================================

# 微信支付商户号
WECHAT_MCH_ID="your-merchant-id"

# 微信支付API密钥
WECHAT_MCH_KEY="your-api-key"

# 微信支付APPID
WECHAT_APP_ID="wx-your-app-id"

# 微信支付回调地址
WECHAT_NOTIFY_URL="https://your-domain.com/api/payment/wechat/notify"

# ===========================================
# 支付宝配置
# ===========================================

# 支付宝应用ID
ALIPAY_APP_ID="your-app-id"

# 支付宝私钥
ALIPAY_PRIVATE_KEY="your-private-key"

# 支付宝公钥
ALIPAY_PUBLIC_KEY="your-alipay-public-key"

# 支付宝回调地址
ALIPAY_NOTIFY_URL="https://your-domain.com/api/payment/alipay/notify"

# 支付宝同步返回地址
ALIPAY_RETURN_URL="https://your-domain.com/payment/result"

# ===========================================
# Redis配置 (可选)
# ===========================================

# REDIS_URL="redis://localhost:6379"

# ===========================================
# 邀请系统配置
# ===========================================

# 邀请奖励金额 (元)
INVITE_REWARD_AMOUNT=10

# ===========================================
# 第三方服务
# ===========================================

# 邮件服务 (可选)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER="noreply@example.com"
# SMTP_PASS="your-password"

# 短信服务 (可选)
# SMS_PROVIDER="aliyun"
# SMS_ACCESS_KEY="your-access-key"
# SMS_ACCESS_SECRET="your-access-secret"
