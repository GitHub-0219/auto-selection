# ===========================================
# 数据库配置
# ===========================================
DATABASE_URL="postgresql://username:password@localhost:5432/ai_cross_border?schema=public"

# ===========================================
# JWT认证配置 (P0修复)
# ===========================================
# 【重要】生产环境必须使用强随机密钥，建议64字符以上
# 生成方法: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-in-production-must-be-at-least-64-chars"
JWT_EXPIRES_IN="7d"

# ===========================================
# 安全限流配置 (P0修复)
# ===========================================
# 登录失败锁定配置
MAX_LOGIN_ATTEMPTS=5           # 最大登录失败次数
LOGIN_LOCKOUT_DURATION=900000  # 锁定时长（毫秒），900000 = 15分钟

# 全局限流配置
THROTTLE_TTL=60000             # 限流窗口（毫秒）
THROTTLE_LIMIT=100             # 每窗口最大请求数

# ===========================================
# 验证码配置 (P0修复)
# ===========================================
# 是否启用验证码（注册时）
ENABLE_CAPTCHA=true
CAPTCHA_CODE_LENGTH=4           # 验证码长度
CAPTCHA_EXPIRY=300             # 验证码有效期（秒）

# ===========================================
# 第三方验证码（可选备选方案）
# ===========================================
# reCAPTCHA配置（可选）
RECAPTCHA_SITE_KEY="your-recaptcha-site-key"
RECAPTCHA_SECRET_KEY="your-recaptcha-secret-key"
RECAPTCHA_ENABLED=false        # 是否启用reCAPTCHA

# ===========================================
# 前端配置
# ===========================================
FRONTEND_URL="http://localhost:3000"

# ===========================================
# 后端服务配置
# ===========================================
PORT=3001
NODE_ENV="development"

# ===========================================
# AI服务配置 (OpenAI / Claude)
# ===========================================
# OpenAI
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
OPENAI_MODEL="gpt-4"
OPENAI_MAX_TOKENS=2000

# Claude (备选)
CLAUDE_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx"
CLAUDE_MODEL="claude-3-sonnet-20240229"

# AI服务选择: openai | claude
AI_PROVIDER="openai"

# ===========================================
# 第三方服务配置
# ===========================================

# 邮件服务 (SendGrid)
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxx"
SENDGRID_FROM_EMAIL="noreply@yourdomain.com"

# 支付服务 (Stripe)
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxx"
