# ===========================================
# Auto选品 - 后端环境配置
# ===========================================
# 重要：复制此文件为 .env 并填入真实值
# 禁止将包含真实密钥的 .env 文件提交到代码仓库
# ===========================================

# ===========================================
# 数据库配置 (生产环境必须启用SSL)
# ===========================================
# 开发环境
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_cross_border?schema=public"
# 
# 生产环境 - AWS RDS示例
# DATABASE_URL="postgresql://user:password@xxx.rds.amazonaws.com:5432/ai_cross_border?schema=public&sslmode=require&sslrootcert=./certs/rds-bundle.pem"
#
# 生产环境 - 自签名证书示例
# DATABASE_URL="postgresql://user:password@host:5432/ai_cross_border?schema=public&sslmode=require&sslcert=./certs/server.crt"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_cross_border?schema=public"

# 数据库SSL配置
DB_SSL_MODE="prefer"  # prefer=优先SSL, require=必须SSL, disable=禁用SSL
DB_SSL_REJECT_UNAUTHORIZED="false"  # 生产环境设为true

# 应用配置
PORT=3001
NODE_ENV="development"  # 生产环境必须设为production
FRONTEND_URL="http://localhost:3000"

# ===========================================
# JWT认证配置 (安全关键)
# ===========================================
# ⚠️ 警告：生产环境必须替换为强随机密钥！
# 生成方法: openssl rand -hex 64
# 密钥要求: 至少64字节(128个十六进制字符)，不得包含demo/test/secret等弱模式
JWT_SECRET="CHANGE_ME_USE_OPENSSL_RAND_HEX_64"  # 示例: a1b2c3... (128字符)
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# 登录安全配置
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=900

# ===========================================
# 限流配置
# ===========================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5

# ===========================================
# Redis配置 (可选，用于缓存和会话)
# ===========================================
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""  # 生产环境必须设置密码

# ===========================================
# AI服务配置
# ===========================================

# AI提供商: siliconflow | mock
AI_PROVIDER="mock"

# 硅基流动API (https://account.siliconflow.cn)
SILICONFLOW_API_KEY="sk-your-api-key-here"
SILICONFLOW_MODEL="Qwen/Qwen2.5-7B-Instruct"

# OpenAI API (备选)
OPENAI_API_KEY="sk-your-openai-key"

# ===========================================
# 微信支付配置
# ===========================================

# 微信支付商户号
WECHAT_MCH_ID="your-merchant-id"

# 微信支付API密钥
WECHAT_MCH_KEY="your-api-key"

# 微信支付APPID
WECHAT_APP_ID="wx-your-app-id"

# 微信支付回调地址
WECHAT_NOTIFY_URL="https://your-domain.com/api/payment/wechat/notify"

# ===========================================
# 支付宝配置
# ===========================================

# 支付宝应用ID
ALIPAY_APP_ID="your-app-id"

# 支付宝私钥
ALIPAY_PRIVATE_KEY="your-private-key"

# 支付宝公钥
ALIPAY_PUBLIC_KEY="your-alipay-public-key"

# 支付宝回调地址
ALIPAY_NOTIFY_URL="https://your-domain.com/api/payment/alipay/notify"

# 支付宝同步返回地址
ALIPAY_RETURN_URL="https://your-domain.com/payment/result"

# ===========================================
# Redis配置 (可选)
# ===========================================

# REDIS_URL="redis://localhost:6379"

# ===========================================
# 邀请系统配置
# ===========================================

# 邀请奖励金额 (元)
INVITE_REWARD_AMOUNT=10

# ===========================================
# 第三方服务
# ===========================================

# 邮件服务 (可选)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER="noreply@example.com"
# SMTP_PASS="your-password"

# 短信服务 (可选)
# SMS_PROVIDER="aliyun"
# SMS_ACCESS_KEY="your-access-key"
# SMS_ACCESS_SECRET="your-access-secret"
